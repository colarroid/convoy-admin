# Admin dashboard environment variables. Copy to .env.local and fill in.
# Never commit real values, .env.local is gitignored.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Full access, keep secret. Used for admin reads/writes.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (community logo uploads, server-signed)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Server-only. Required for the /api/cloudinary/sign route, keep secret.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps (address autocomplete on community forms)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
